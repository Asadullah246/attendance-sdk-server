# Server
PORT=8081
NODE_ENV=development

# Database
# Replace with your PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/zkteco_sdk

# API Security
# This key must be sent in the 'x-api-key' header when calling /api/v1/* routes
API_KEY=your_secure_api_key_here

# Dashboard Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=securepassword123

# Webhooks (Main Application Destination)
# The URL where the SDK server will push attendance and sync logs
MAIN_APP_WEBHOOK_URL=https://your-main-app.com/api/webhooks/zkteco
# A secret attached to the 'x-webhook-secret' header for your Main App to verify
WEBHOOK_SECRET=your_secure_webhook_secret_here

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Device Defaults
DEFAULT_DEVICE_IP=192.168.0.210
DEFAULT_DEVICE_PORT=4370
CONNECTION_TIMEOUT=15000
